{
  "expo": {
    "name": "Karma Tracker",
    "slug": "karma-tracker",
    "owner": "snorlaxida",
    "scheme": "karma-tracker",
    "version": "1.0.0",
    "orientation": "portrait",
    "userInterfaceStyle": "automatic",
    "assetBundlePatterns": [
      "**/*"
    ],
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.biggoatssoft.karmatracker",
      "usesAppleSignIn": true,
      "entitlements": {
        "com.apple.developer.applesignin": [
          "Default",
          "Default"
        ]
      },
      "infoPlist": {
        "CFBundleURLTypes": [
          {
            "CFBundleURLSchemes": [
              "com.googleusercontent.apps.279743954969-7qnfkv9c22ppq5k117so89sbrqb1gtqq"
            ]
          },
          {
            "CFBundleURLSchemes": [
              "com.googleusercontent.apps.279743954969-7qnfkv9c22ppq5k117so89sbrqb1gtqq"
            ]
          }
        ],
        "ITSAppUsesNonExemptEncryption": false
      }
    },
    "android": {
      "package": "com.biggoatssoft.karmatracker"
    },
    "web": {
      "bundler": "metro"
    },
    "plugins": [
      "expo-font",
      "expo-web-browser",
      "react-native-iap",
      "expo-apple-authentication"
    ],
    "extra": {
      "eas": {
        "projectId": "b0ac772d-ab65-41af-a806-e0bd62eb9743"
      }
    }
  }
}
